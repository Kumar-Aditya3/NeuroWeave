{
  "manifest_version": 3,
  "name": "NeuroWeave Capture",
  "version": "0.1.0",
  "description": "Opt-in browser activity capture for NeuroWeave.",
  "permissions": ["tabs", "storage"],
  "host_permissions": [
    "http://127.0.0.1:8000/*",
    "http://localhost:8000/*",
    "https://*.supabase.co/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "NeuroWeave"
  }
}
